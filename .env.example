# --- Qwen Cloud (Alibaba Cloud Model Studio, formerly DashScope) ---
# Get a key from your Model Studio console's API-KEY page. NOTE: as of the
# 2026 Model Studio rebrand, the base URL is workspace-specific -- it is
# NOT the old generic dashscope-intl.aliyuncs.com host. Find your workspace's
# "OpenAI Compatible Endpoint" value on the console's API-KEY / Base URL page
# (looks like https://ws-<your-workspace-id>.<region>.maas.aliyuncs.com/compatible-mode/v1)
# and use that instead of the placeholder below.
QWEN_API_KEY=your-model-studio-api-key-here
QWEN_BASE_URL=https://ws-your-workspace-id.eu-central-1.maas.aliyuncs.com/compatible-mode/v1
QWEN_CHAT_MODEL=qwen-max
QWEN_EMBEDDING_MODEL=text-embedding-v3

# --- Postgres ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=synapse
POSTGRES_USER=synapse
POSTGRES_PASSWORD=synapse_dev_password
DATABASE_URL=postgresql+psycopg://synapse:synapse_dev_password@localhost:5432/synapse

# --- Memory engine config (see backend/app/config.py for full list) ---
DECAY_HALFLIFE_HOURS_SEMANTIC=720
DECAY_HALFLIFE_HOURS_EPISODIC=72
DECAY_HALFLIFE_HOURS_CONSOLIDATED=720
PRUNE_SALIENCE_FLOOR=0.05
RETRIEVAL_TOP_N=25
RETRIEVAL_TOP_K=6
CONSOLIDATION_SIMILARITY_THRESHOLD=0.86
CONSOLIDATION_MIN_CLUSTER_SIZE=3
CONSOLIDATION_TRIGGER_EVERY_N_WRITES=20
SUPERSESSION_SIMILARITY_GATE=0.55
RETRIEVAL_RELEVANCE_FLOOR=0.6

# --- App ---
APP_ENV=development
CORS_ORIGINS=http://localhost:5173
